#!/bin/sh
# pre-push — the LOCAL gate that carries the real weight for this meta-package.
#
# ai-helpers CI on the server is intentionally tiny (it only builds the package
# and dry-run-resolves the suite graph — see .github/workflows/ci.yml). The
# expensive proof that the documented examples actually RUN lives here, on the
# coder's machine, so a fault is caught before it ever reaches the server:
#   * the deterministic offline composed example (audio -> transcript ->
#     docx/pdf) runs for real on a committed speech clip;
#   * the YouTube acquisition example runs on the coder's residential IP —
#     something CI genuinely cannot do (YouTube bot-blocks datacenter IPs even
#     with cookies, per yt-dlp #12045 / #15392).
# If any of these fail, the push is aborted, so a broken example never reaches
# users.
#
# Enable once per clone:   git config core.hooksPath .githooks
# Bypass in a pinch:       git push --no-verify

# Locate a python that has pytest. On a machine without the suite installed
# (e.g. a docs-only checkout) we do NOT block the push — the module's own skip
# guards already make the tests a no-op there, and the server still resolves the
# graph.
PY="$(command -v python3 || command -v python)"
if [ -z "$PY" ] || ! "$PY" -c "import pytest" >/dev/null 2>&1; then
  echo "pre-push: pytest not available here — skipping the local example gate."
  exit 0
fi

# Run the full example suite locally: the offline composed example (no network)
# plus the YouTube acquisition (short audio pull). The heavier full-video "quick
# example" stays an opt-in `-m slow` run so the everyday gate stays quick.
echo "pre-push: running the example tests locally (the server CI stays light and does not)..."
if ! "$PY" -m pytest tests/test_examples.py -q; then
  echo ""
  echo "pre-push: the local example tests FAILED — push aborted."
  echo "  Fix them, or bypass once with:  git push --no-verify"
  exit 1
fi
echo "pre-push: example tests passed — pushing."
exit 0
